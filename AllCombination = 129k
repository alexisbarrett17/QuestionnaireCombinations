def build_payload_from_selection(selection: dict):
    """
    selection: dict mapping field -> chosen option (remoteAccess uses tuple (Yes/No, types))
    Applies chosen options on top of DEFAULT_SECURITY.
    """
    sq = copy.deepcopy(DEFAULT_SECURITY)

    for field, value in selection.items():
        if field == "remoteAccess":
            remote_val, types = value
            sq["remoteAccess"] = remote_val
            sq["remoteAccessTypes"] = types
        else:
            sq[field] = value

    payload = copy.deepcopy(BASE_PAYLOAD)
    payload["securityQuestions"] = sq
    return payload

def make_label(selection: dict):
    parts = []
    for f in FIELD_ORDER:
        v = selection[f]
        if f == "remoteAccess":
            rv, types = v
            parts.append(f"{f}={rv}({', '.join(types) if types else 'no staff'})")
        else:
            parts.append(f"{f}={v}")
    return " | ".join(parts)

def call_api(payload):
    if DRY_RUN:
        return 200, json.dumps({"dry_run": True, "status": "ok"})
    try:
        r = requests.post(API_URL, headers=API_HEADERS, json=payload, timeout=TIMEOUT)
        return r.status_code, r.text
    except requests.exceptions.Timeout:
        return 0, "ERROR: Request timed out"
    except Exception as e:
        return 0, f"ERROR: {e}"

def flatten(obj, prefix=""):
    rows = []
    if isinstance(obj, dict):
        for k, v in obj.items():
            fk = f"{prefix}.{k}" if prefix else k
            if isinstance(v, (dict, list)):
                rows.extend(flatten(v, fk))
            else:
                rows.append((fk, "" if v is None else str(v)))
    elif isinstance(obj, list):
        for i, item in enumerate(obj):
            fk = f"{prefix}[{i}]"
            if isinstance(item, (dict, list)):
                rows.extend(flatten(item, fk))
            else:
                rows.append((fk, "" if item is None else str(item)))
    return rows

def parse_response(text):
    try:
        return flatten(json.loads(text))
    except Exception:
        return [("response", text)]

def write_excel(results):
    wb = Workbook()
    ws = wb.active
    ws.title = "Results"

    hfont_j = Font(name="Arial", bold=True, color="FFFFFF", size=10)
    hfont_a = Font(name="Arial", bold=True, color="FFFFFF", size=10)
    hfill_j = PatternFill("solid", start_color="1F4E79")
    hfill_a = PatternFill("solid", start_color="375623")
    gfill   = PatternFill("solid", start_color="BDD7EE")
    altfill = PatternFill("solid", start_color="EBF3FB")
    dfont   = Font(name="Arial", size=9)
    left    = Alignment(horizontal="left", vertical="top", wrap_text=True)
    center  = Alignment(horizontal="center", vertical="top")
    thin    = Border(
        left=Side(style="thin", color="D9D9D9"), right=Side(style="thin", color="D9D9D9"),
        top=Side(style="thin", color="D9D9D9"),  bottom=Side(style="thin", color="D9D9D9")
    )

    for idx, (label, payload, status, response) in enumerate(results):
        jcol = 2 * idx + 1
        acol = 2 * idx + 2
        if acol > 16384:
            raise RuntimeError("Excel column limit exceeded (16384). Reduce MAX_COMBOS or change output format.")
        jlet = get_column_letter(jcol)
        alet = get_column_letter(acol)

        c = ws.cell(row=1, column=jcol, value=label)
        c.font = Font(name="Arial", bold=True, size=10); c.fill = gfill; c.alignment = center
        ws.cell(row=1, column=acol).fill = gfill

        c = ws.cell(row=2, column=jcol, value="JSON Key / Value")
        c.font = hfont_j; c.fill = hfill_j; c.alignment = center

        c = ws.cell(row=2, column=acol, value=f"API Response (HTTP {status})")
        c.font = hfont_a; c.fill = hfill_a; c.alignment = center

        jrows = flatten(payload)
        arows = parse_response(response)

        for r in range(max(len(jrows), len(arows))):
            row = r + 3
            fill = altfill if r % 2 == 1 else None
            if r < len(jrows):
                k, v = jrows[r]
                c = ws.cell(row=row, column=jcol, value=f"{k}: {v}")
                c.font = dfont; c.alignment = left; c.border = thin
                if fill: c.fill = fill
            if r < len(arows):
                k, v = arows[r]
                c = ws.cell(row=row, column=acol, value=f"{k}: {v}")
                c.font = dfont; c.alignment = left; c.border = thin
                if fill: c.fill = fill

        ws.column_dimensions[jlet].width = 55
        ws.column_dimensions[alet].width = 55

    ws.freeze_panes = "A3"
    wb.save(OUTPUT_FILE)
    print(f"Saved → {OUTPUT_FILE}")

def ordered_fullfactorial_generator():
    """
    Yields selection dicts in nested-loop order:
      for q1 in opts1:
        for q2 in opts2:
          ...
            yield {q1:..., q2:..., ...}
    """
    option_lists = [FIELD_VARIATIONS[f] for f in FIELD_ORDER]
    for combo in itertools.product(*option_lists):
        selection = {FIELD_ORDER[i]: combo[i] for i in range(len(FIELD_ORDER))}
        yield selection

def main():
    print("=" * 65)
    print("  ORDERED FULL-FACTORIAL (Nested Q1 -> Q2 -> ... -> QN)")
    print("=" * 65)

    # Compute theoretical total combos
    total = 1
    for f in FIELD_ORDER:
        total *= len(FIELD_VARIATIONS[f])
    print(f"Theoretical total combos (cartesian product): {total:,}")
    print(f"MAX_COMBOS (will actually run): {MAX_COMBOS:,}")
    print("NOTE: This Excel layout supports at most 8,192 combos (2 cols per combo).")

    results = []
    gen = ordered_fullfactorial_generator()

    for i, selection in enumerate(gen, start=1):
        if i > MAX_COMBOS:
            break

        label = make_label(selection)
        payload = build_payload_from_selection(selection)

        status, response = call_api(payload)
        results.append((label, payload, status, response))

        print(f"  [{i}/{min(MAX_COMBOS, total)}] → HTTP {status} | {label[:120]}{'...' if len(label) > 120 else ''}")

        if not DRY_RUN and i < min(MAX_COMBOS, total):
            time.sleep(DELAY)

    write_excel(results)
    success = sum(1 for _, _, s, _ in results if 200 <= s < 300)
    print(f"\nDone! {len(results)} combos | ✅ {success} success | ❌ {len(results)-success} errors")

if __name__ == "__main__":
    main()
