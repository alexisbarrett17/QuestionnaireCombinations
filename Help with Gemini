# ─── LOGIC FUNCTIONS ──────────────────────────────────────────────────────────

def build_payload(field_name, value):
    sq = copy.deepcopy(DEFAULT_SECURITY)
    if field_name == "remoteAccess":
        sq["remoteAccess"], sq["remoteAccessTypes"] = value
    elif field_name != "BASELINE":
        sq[field_name] = value

    payload = copy.deepcopy(BASE_PAYLOAD)
    payload["securityQuestions"] = sq
    return payload


def call_api(payload):
    if DRY_RUN:
        return 200, json.dumps({"dry_run": "success", "sample_output": 100})
    try:
        # Note: requests.post(json=...) automatically sets header to application/json
        r = requests.post(API_URL, json=payload, timeout=TIMEOUT)
        return r.status_code, r.text
    except Exception as e:
        return 0, f"CONNECTION ERROR: {str(e)}"


def flatten(obj, prefix=""):
    rows = []
    if isinstance(obj, dict):
        for k, v in obj.items():
            fk = f"{prefix}.{k}" if prefix else k
            if isinstance(v, (dict, list)):
                rows.extend(flatten(v, fk))
            else:
                rows.append((fk, str(v)))
    elif isinstance(obj, list):
        for i, item in enumerate(obj):
            fk = f"{prefix}[{i}]"
            if isinstance(item, (dict, list)):
                rows.extend(flatten(item, fk))
            else:
                rows.append((fk, str(item)))
    return rows


def parse_response(text):
    try:
        return flatten(json.loads(text))
    except:
        return [("raw_response", text)]


def write_excel(results):
    wb = Workbook()
    ws = wb.active
    ws.title = "API Variation Test"

    # Styles
    header_font = Font(bold=True, color="FFFFFF")
    header_fill = PatternFill("solid", start_color="1F4E79")
    highlight_fill = PatternFill("solid", start_color="FFFF00")  # Yellow for changed fields
    error_fill = PatternFill("solid", start_color="FFC7CE")
    border = Border(left=Side(style='thin', color='D9D9D9'), right=Side(style='thin', color='D9D9D9'),
                    top=Side(style='thin', color='D9D9D9'), bottom=Side(style='thin', color='D9D9D9'))
    align = Alignment(horizontal="left", vertical="top", wrap_text=True)

    for idx, (label, field_key, payload, status, response) in enumerate(results):
        col_start = (idx * 2) + 1

        # Header
        ws.merge_cells(start_row=1, start_column=col_start, end_row=1, end_column=col_start + 1)
        c = ws.cell(row=1, column=col_start, value=label)
        c.font = Font(bold=True);
        c.alignment = Alignment(horizontal="center")

        # Sub-headers
        h1 = ws.cell(row=2, column=col_start, value="Request Payload")
        h2 = ws.cell(row=2, column=col_start + 1, value=f"Response (HTTP {status})")
        for h in [h1, h2]:
            h.font = header_font;
            h.fill = header_fill;
            h.alignment = Alignment(horizontal="center")
        if status != 200: h2.fill = error_fill

        req_rows = flatten(payload)
        res_rows = parse_response(response)

        for r in range(max(len(req_rows), len(res_rows))):
            curr_row = r + 3
            # Write Request Column
            if r < len(req_rows):
                k, v = req_rows[r]
                cell = ws.cell(row=curr_row, column=col_start, value=f"{k}: {v}")
                cell.border = border;
                cell.alignment = align
                # Highlight if this is the key we changed
                if field_key in k:
                    cell.fill = highlight_fill

            # Write Response Column
            if r < len(res_rows):
                k, v = res_rows[r]
                cell = ws.cell(row=curr_row, column=col_start + 1, value=f"{k}: {v}")
                cell.border = border;
                cell.alignment = align

        ws.column_dimensions[get_column_letter(col_start)].width = 45
        ws.column_dimensions[get_column_letter(col_start + 1)].width = 45

    ws.freeze_panes = "A3"
    wb.save(OUTPUT_FILE)
    print(f"\nExcel saved as: {OUTPUT_FILE}")


# ─── MAIN EXECUTION ───────────────────────────────────────────────────────────

def main():
    print("Starting API Stress Test...")

    # Setup test queue
    queue = [("BASELINE", "none", "BASELINE (Default)")]
    for field, options in FIELD_VARIATIONS.items():
        for opt in options:
            queue.append((field, opt, f"Test: {field}"))

    results = []
    for i, (field, opt, label) in enumerate(queue):
        payload = build_payload(field, opt)
        status, response = call_api(payload)
        results.append((label, field, payload, status, response))

        # Console logging
        indicator = "✅" if status == 200 else "❌"
        print(f"[{i + 1}/{len(queue)}] {indicator} {label} ({opt}) -> HTTP {status}")

        if not DRY_RUN:
            time.sleep(DELAY)

    write_excel(results)


if __name__ == "__main__":
    main()
